---
export const prerender = true;

import { defaultLocale } from "@/docs/config/siteSettings.json";
import { docsRoute } from "@/docs/js/docsUtils";
import { getLocalizedRoute } from "@/docs/js/translationUtils";

export async function getStaticPaths() {
  const localizedDocsRoute = getLocalizedRoute(defaultLocale, docsRoute)
    .replace(/^\/|\/$/g, "")
    .replace(/^[^/]+\//, "");

  return [
    {
      params: { docsRoute: localizedDocsRoute },
    },
  ];
}
---

<html>
  <head>
    <meta http-equiv="refresh" content={`0;url=/${docsRoute}/getting-started/`} />
  </head>
</html>
