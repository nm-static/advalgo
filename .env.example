# Resend Email Service
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxx

# Optional: Custom "from" email (requires verified domain in Resend)
# Default: "Course Portal <noreply@resend.dev>"
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Google Sheets - One Sheet ID per batch
# Get the Sheet ID from the URL: https://docs.google.com/spreadsheets/d/{SHEET_ID}/edit
# Add a new variable for each batch you teach
GOOGLE_SHEETS_ID_2026=your-2026-sheet-id
GOOGLE_SHEETS_ID_2027=your-2027-sheet-id

# Google Service Account (same account works for all sheets - just share each sheet with it)
# Create a service account at https://console.cloud.google.com/iam-admin/serviceaccounts
# Enable Google Sheets API: https://console.cloud.google.com/apis/library/sheets.googleapis.com
# Download JSON key and copy these values:
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# JWT Secret for session tokens
# Generate a random 32+ character string
JWT_SECRET=your-random-secret-string-at-least-32-chars
